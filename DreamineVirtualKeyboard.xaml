<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dreamine.UI.Maui.DreamineVirtualKeyboard"
             IsVisible="False">

    <Border BackgroundColor="#000000" Stroke="#808080" StrokeThickness="4" Padding="18,14">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16" />
        </Border.StrokeShape>

        <VerticalStackLayout x:Name="RowsHost" Spacing="4" />
    </Border>
</ContentView>
