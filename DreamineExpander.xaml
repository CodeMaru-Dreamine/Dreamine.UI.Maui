<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dreamine.UI.Maui.DreamineExpander">

    <Border BackgroundColor="White" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="6" />
        </Border.StrokeShape>

        <VerticalStackLayout>
            <Grid x:Name="HeaderRow" ColumnDefinitions="Auto,*" Padding="12,8" BackgroundColor="#E9EEF5">
                <Label x:Name="ArrowLabel" Grid.Column="0" Text="▼" TextColor="Black" Margin="0,0,8,0" />
                <Label x:Name="HeaderLabel" Grid.Column="1" TextColor="Black" FontAttributes="Bold" VerticalOptions="Center" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHeaderTapped" />
                </Grid.GestureRecognizers>
            </Grid>

            <ContentView x:Name="ContentHost" Padding="12" />
        </VerticalStackLayout>
    </Border>
</ContentView>
