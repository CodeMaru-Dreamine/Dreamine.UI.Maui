<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dreamine.UI.Maui.Popup.BlinkPopupPage"
             BackgroundColor="#80000000">

    <Border x:Name="Card"
            Stroke="#5AFFFFFF"
            StrokeThickness="1.5"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="380"
            Padding="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="0" />
        </Border.StrokeShape>

        <Grid RowDefinitions="64,Auto,Auto" RowSpacing="0" Padding="0,0,0,16">
            <Label x:Name="TitleLabel" Grid.Row="0" FontAttributes="Bold" FontSize="24"
                   HorizontalOptions="Center" VerticalOptions="Center" />

            <Label x:Name="MessageLabel" Grid.Row="1" FontSize="14"
                   HorizontalOptions="Center" Margin="20,12,20,12" LineBreakMode="WordWrap" />

            <HorizontalStackLayout x:Name="ButtonRow" Grid.Row="2"
                   HorizontalOptions="Center" Spacing="8" />
        </Grid>
    </Border>
</ContentPage>
